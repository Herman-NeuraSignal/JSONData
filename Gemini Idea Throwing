    <script>
        // --- 1. Scene Setup ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x1a1a1a);

        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 1, 500);
        camera.position.set(30, 40, 80); // Isometric perspective angle

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.target.set(0, 0, -35); // Focus camera orbit track on the intersection area
        controls.update();

        // --- 2. Lighting Setup ---
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
        dirLight.position.set(20, 40, 20);
        scene.add(dirLight);

        // --- 3. Base Coordinate Grid & Guide Axis ---
        // Blue axis = Z (Depth), Red = X, Green = Y
        const axesHelper = new THREE.AxesHelper(15);
        scene.add(axesHelper);

        const gridHelper = new THREE.GridHelper(60, 20, 0x444444, 0x333333);
        gridHelper.rotation.x = Math.PI / 2; // Orient grid flat relative to scan depth
        scene.add(gridHelper);

        // --- 4. Render L-MCA Artery Segment (Z: 47mm to 53mm) ---
        const vesselRadius = 3;
        const vesselLength = 6; // 53mm - 47mm
        const vesselGeo = new THREE.CylinderGeometry(vesselRadius, vesselRadius, vesselLength, 32);
        const vesselMat = new THREE.MeshPhongMaterial({
            color: 0x00ccff,
            transparent: true,
            opacity: 0.4,
            side: THREE.DoubleSide
        });
        const vessel = new THREE.Mesh(vesselGeo, vesselMat);
        
        // In Three.js, cylinders default vertical. Rotate and push down Z-axis to depth [47, 53]
        vessel.rotation.x = Math.PI / 2;
        vessel.position.set(0, 0, -50); 
        scene.add(vessel);

        // --- 5. Render Hourglass Beam Geometry ---
        // Built by stacking micro cylinder rings along the Z trajectory path
        const beamGroup = new THREE.Group();
        const focusDepth = 50;
        const waistRadius = 1;
        const divergenceScale = 0.015;

        for (let z = 0; z <= 60; z += 1) {
            // Hourglass formula matched straight to your JSON definition
            const currentRadius = waistRadius + divergenceScale * Math.pow((z - focusDepth), 2);
            
            const ringGeo = new THREE.CylinderGeometry(currentRadius, currentRadius, 1, 16, 1, true);
            const ringMat = new THREE.MeshBasicMaterial({
                color: 0xff9900,
                wireframe: true,
                transparent: true,
                opacity: 0.15
            });
            const ring = new THREE.Mesh(ringGeo, ringMat);
            ring.rotation.x = Math.PI / 2;
            ring.position.set(0, 0, -z);
            beamGroup.add(ring);
        }
        scene.add(beamGroup);

        // --- 6. Render Hit Samples (n=60 for visual clarity) ---
        const sampleCount = 60;
        const dotGeo = new THREE.SphereGeometry(0.3, 8, 8);
        const dotMat = new THREE.MeshBasicMaterial({ color: 0xff3366 });

        for (let i = 0; i < sampleCount; i++) {
            const dot = new THREE.Mesh(dotGeo, dotMat);
            // Randomly scatter positions strictly constrained within the target boundaries
            const zRand = -(47 + Math.random() * 6);
            const angleRand = Math.random() * Math.PI * 2;
            const rRand = Math.random() * waistRadius;
            
            const xRand = rRand * Math.cos(angleRand);
            const yRand = rRand * Math.sin(angleRand);

            dot.position.set(xRand, yRand, zRand);
            scene.add(dot);
        }

        // --- 7. Animation Loop ---
        function animate() {
            requestAnimationFrame(animate);
            // Slow orbit preview if user isn't interacting manually
            if(!controls.state == -1) {
                scene.rotation.z += 0.002;
            }
            renderer.render(scene, camera);
        }
        animate();

        // Handle window resizing cleanly
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }
    </script>
