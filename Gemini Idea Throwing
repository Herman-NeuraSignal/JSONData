python
import json
import os
from typing import Dict, Any
# Force matplotlib to use a headless backend before importing pyplot
import matplotlib
matplotlib.use('Agg') 
import matplotlib.pyplot as plt

def export_scene_artifact(
    scene_data: Any,  # e.g., SyntheticMCA from synthetic.py
    beam_geometry: Any,  # e.g., Beam from beam.py
    window_axes: Any,  # e.g., Window from window.py
    output_dir: str,
    base_filename: str = "synthetic_straight_mca_v0_1"
) -> tuple[str, str]:
    """
    Generates a deterministic static PNG visualization and a JSON sidecar.
    Safe for headless CI execution.
    """
    png_path = os.path.join(output_dir, f"{base_filename}.png")
    json_path = os.path.join(output_dir, f"{base_filename}.json")
    
    # 1. Generate Metadata Sidecar Payload
    metadata: Dict[str, Any] = {
        "scene_id": getattr(scene_data, "scene_id", "synthetic_straight_mca_v0_1"),
        "vessel_label": "L-MCA",
        "coordinate_frame": "world",
        "units": "millimeter",
        "renderer_name": "collision_sim_mvp.vis.scene_exporter",
        "renderer_version": "0.1.0",
        "inputs": {
            "beam_angle_deg": getattr(beam_geometry, "angle", 0.0),
            "window_origin_mm": getattr(window_axes, "origin", [0, 0, 0]),
        }
    }
    
    # 2. Render Static Plot
    fig, ax = plt.subplots(figsize=(6, 6))
    
    # Example: Plot synthetic vessel geometric bounds
    # Replace these lines with your actual geometry extracts from scene/synthetic.py
    if hasattr(scene_data, "get_geometry_points"):
        x, y = scene_data.get_geometry_points()
        ax.plot(x, y, label="L-MCA Vessel Profile", color="blue")
    
    # Example: Plot beam trajectory reference line
    if hasattr(beam_geometry, "get_trajectory_line"):
        bx, by = beam_geometry.get_trajectory_line()
        ax.plot(bx, by, '--', label="Default Beam Probe", color="orange")
        
    ax.set_title(f"Scene: {metadata['scene_id']} Reference View")
    ax.set_xlabel("X (mm)")
    ax.set_ylabel("Y (mm)")
    ax.legend()
    ax.grid(True)
    
    # Save the PNG headlessly
    plt.savefig(png_path, dpi=150, bbox_inches='tight')
    plt.close(fig) # Prevent memory leaks in loops
    
    # 3. Write Metadata Sidecar
    with open(json_path, 'w', encoding='utf-8') as f:
        json.dump(metadata, f, indent=2)
        
    return png_path, json_path
