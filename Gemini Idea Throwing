    vessel_z = np.linspace(z_min, z_max, 20)
    theta = np.linspace(0, 2 * np.pi, 20)
    vessel_Z, vessel_theta = np.meshgrid(vessel_z, theta)
    
    # Center the cylinder relative to command offsets
    vessel_X = vessel_radius * np.cos(vessel_theta) + cmd["x_mm"]
    vessel_Y = vessel_radius * np.sin(vessel_theta) + cmd["y_mm"]
    
    ax.plot_surface(vessel_X, vessel_Y, vessel_Z, color='deepskyblue', alpha=0.3, label="L-MCA Artery")

    # -----------------------------------------------------------------
